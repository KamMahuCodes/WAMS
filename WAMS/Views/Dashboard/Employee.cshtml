@model WAMS.Models.ViewModels.EmployeeDashboardViewModel
@{
    ViewData["Title"] = "Employee Dashboard";
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml";
}

<div class="container-fluid p-4">

    <!-- METRICS -->
    <div class="row g-4 mb-4">

        <div class="col-md-4">
            <div class="card card-warning p-4">
                <h5>My Pending Requests</h5>
                <h2 id="myPending">@Model.MyPendingRequests</h2>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card card-success p-4">
                <h5>My Approved Requests</h5>
                <h2 id="myApproved">@Model.MyApprovedRequests</h2>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card card-danger p-4">
                <h5>My Rejected Requests</h5>
                <h2 id="myRejected">@Model.MyRejectedRequests</h2>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card card-primary p-4">
                <h5>Approval Rate</h5>
                <h2>@Model.ApprovalRate %</h2>
            </div>
        </div>

    </div>

    <!-- CHART -->
    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card card-primary p-4">
                <h5>My Request Status</h5>
                <div style="height:300px;">
                    <canvas id="employeeChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- RECENT REQUESTS -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card shadow-sm p-4">
                <h5>Recent Requests</h5>

                @if (Model.RecentRequests == null || !Model.RecentRequests.Any())
                {
                    <div class="alert alert-info mt-3">
                        No recent requests found.
                    </div>
                }
                else
                {
                    <table class="table table-hover mt-3">
                        <thead>
                            <tr>
                                <th>Request Type</th>
                                <th>Status</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.RecentRequests)
                            {
                                <tr>
                                    <td>@item.EmployeeName</td>
                                    <td>
                                        <span class="badge bg-@(
                                              item.Decision == "Approved" ? "success" :
                                              item.Decision == "Rejected" ? "danger" :
                                              "warning")">
                                            @item.Decision
                                        </span>
                                    </td>
                                    <td>@item.Date.ToString("dd MMM yyyy HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {

                    document.getElementById('myPending').textContent = @Model.MyPendingRequests;
        document.getElementById('myApproved').textContent = @Model.MyApprovedRequests;
        document.getElementById('myRejected').textContent = @Model.MyRejectedRequests;

            const ctx = document.getElementById('employeeChart');

            new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: ['Approved', 'Rejected', 'Pending'],
                    datasets: [{
                        data: [
                            @Model.MyApprovedRequests,
                            @Model.MyRejectedRequests,
                            @Model.MyPendingRequests
                        ],
                        backgroundColor: [
                            '#28a745',
                            '#dc3545',
                            '#ffc107'
                        ]
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom'
                        }
                    }
                }
            });

        });
    </script>
}