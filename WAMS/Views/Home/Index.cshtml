@{
    ViewData["Title"] = "FlowApprove | Workflow Approval Management System";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="~/css/site.css" />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <style>
        body {
            font-family: 'Nunito', sans-serif;
            margin: 0;
            background-color: #f4f6f9;
            color: #2f3542;
        }

        /* HERO */
        .hero {
            background: linear-gradient(135deg, #1e3c72, #2a5298);
            color: #fff;
            padding: 110px 20px 90px;
            text-align: center;
        }

        .hero-content {
            max-width: 820px;
            margin: auto;
        }

        .hero h1 {
            font-size: 3rem;
            margin-bottom: 20px;
            font-weight: 700;
        }

        .hero p {
            font-size: 1.25rem;
            margin-bottom: 15px;
            opacity: 0.95;
        }

        .hero span {
            display: inline-block;
            margin-top: 20px;
            font-weight: 600;
            letter-spacing: 0.5px;
            color: #e3eaff;
        }

        /* SECTION */
        .section {
            max-width: 1200px;
            margin: 70px auto;
            padding: 0 20px;
        }

        .section-title {
            text-align: center;
            margin-bottom: 50px;
        }

            .section-title h2 {
                font-size: 2.2rem;
                color: #fff;
                margin-bottom: 10px;
            }

            .section-title p {
                color: #57606f;
                background-color: #ffffff;
                padding: 6px 14px;
                border-radius: 999px;
                display: inline-block;
                line-height: 1.5;
                box-shadow: 0 0 0 1px rgba(0,0,0,0.04);
            }

        /* WORKFLOW STEPS */
        .workflow {
            display: flex;
            gap: 25px;
            flex-wrap: wrap;
            justify-content: center;
        }

        .step {
            flex: 1 1 260px;
            background: #fff;
            border-radius: 12px;
            padding: 30px 25px;
            box-shadow: 0 6px 18px rgba(0,0,0,0.08);
            text-align: center;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

            .step:hover {
                transform: translateY(-6px);
                box-shadow: 0 14px 30px rgba(0,0,0,0.12);
            }

            .step i {
                font-size: 2.8rem;
                color: #2a5298;
                margin-bottom: 18px;
            }

            .step h4 {
                color: #fff;
                margin-bottom: 12px;
            }

            .step p {
                font-size: 0.95rem;
                color: #57606f;
                
            }

        /* ENTERPRISE FEATURES */
        .features {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 25px;
        }

        .feature {
            background: #ffffff;
            border-left: 6px solid #2a5298;
            padding: 25px 20px;
            border-radius: 10px;
            box-shadow: 0 6px 16px rgba(0,0,0,0.07);
        }

            .feature h4 {
                color: #1e3c72;
                margin-bottom: 10px;
            }

            .feature p {
                font-size: 0.95rem;
                color: #57606f;
            }

        /* TRUST SECTION */
        .trust {
            background: #e9eef8;
            padding: 60px 20px;
            text-align: center;
        }

            .trust blockquote {
                max-width: 750px;
                margin: auto;
                font-style: italic;
                font-size: 1.1rem;
                color: #2f3542;
            }

            .trust cite {
                display: block;
                margin-top: 15px;
                font-weight: 700;
                color: #1e3c72;
            }

        @@media(max-width: 768px) {
            .hero h1 {
                font-size: 2.3rem;
            }
        }
    </style>
</head>

<body>

    <!-- HERO -->
    <section class="hero">
        <div class="hero-content">
            <h1>Workflow Approval Management System</h1>
            <p>Centralise requests, approvals, and accountability across your organisation.</p>
            <span>SUBMIT • REVIEW • APPROVE • AUDIT</span>
        </div>
    </section>

    <!-- WORKFLOW OVERVIEW -->
    <section class="section">
        <div class="section-title">
            <h2>How FlowApprove Works</h2>
            <p>A structured, role-based approval lifecycle</p>
        </div>

        <div class="workflow">
            <div class="step">
                <i class="fas fa-file-circle-plus"></i>
                <h4>Submit Request</h4>
                <p>Employees initiate requests with supporting documents and details.</p>
            </div>

            <div class="step">
                <i class="fas fa-user-check"></i>
                <h4>Manager Review</h4>
                <p>Line managers validate and approve based on policy rules.</p>
            </div>

            <div class="step">
                <i class="fas fa-clipboard-check"></i>
                <h4>HR / Admin Approval</h4>
                <p>Final approval ensures compliance and audit readiness.</p>
            </div>

            <div class="step">
                <i class="fas fa-clock-rotate-left"></i>
                <h4>Audit & Tracking</h4>
                <p>Every action is logged for accountability and reporting.</p>
            </div>
        </div>
    </section>

    <!-- ENTERPRISE FEATURES -->
    <section class="section">
        <div class="section-title">
            <h2>Built for Enterprise Control</h2>
            <p>Security, visibility, and governance at every step</p>
        </div>

        <div class="features">
            <div class="feature">
                <h4>Role-Based Access</h4>
                <p>Granular permissions for employees, managers, HR, and administrators.</p>
            </div>

            <div class="feature">
                <h4>Policy Enforcement</h4>
                <p>Approval rules aligned with organisational policies.</p>
            </div>

            <div class="feature">
                <h4>Real-Time Notifications</h4>
                <p>Email and in-system alerts for pending approvals.</p>
            </div>

            <div class="feature">
                <h4>Audit-Ready Reports</h4>
                <p>Exportable logs and approval histories for compliance checks.</p>
            </div>
        </div>
    </section>

    <!-- TRUST -->
    <section class="trust">
        <blockquote>
            “FlowApprove replaced scattered email approvals with a single, auditable workflow platform.”
            <cite>— Enterprise Operations Manager</cite>
        </blockquote>
    </section>

</body>
</html>
