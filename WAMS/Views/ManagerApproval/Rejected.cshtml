@model IEnumerable<WAMS.Models.EmployeeRequest>

@{
	ViewData["Title"] = "Rejected Requests";
	Layout = "~/Views/Shared/_ManagerLayout.cshtml";
	
}

<h2 class="mb-4">Rejected</h2>

@if (!Model.Any())
{
	<div class="alert alert-info">
		No leave requests rejected yet.
	</div>
}
else
{
	<div class="card shadow-sm">
		<div class="table-responsive">
			<table class="table table-hover align-middle mb-0">
				<thead class="table-light">
					<tr>
						<th>Employee</th>
						<th>Start Date</th>
						<th>End Date</th>
						<th>Days</th>
						<th>Submitted</th>
						<th class="text-end">Action</th>
					</tr>
				</thead>
				<tbody>
					@foreach (var item in Model)
					{
						<tr>
							<td>
								<strong>@item.Employee?.FullName</strong>
							</td>
							<td>@item.StartDate.ToShortDateString()</td>
							<td>@item.EndDate.ToShortDateString()</td>
							<td>
								@((item.EndDate - item.StartDate).Days + 1)
							</td>
							<td>@item.CreatedAt.ToShortDateString()</td>
							<td class="text-end">
								<a asp-action="Details"
								   asp-route-id="@item.Id"
								   class="btn btn-sm btn-primary">
									Review
								</a>
							</td>
						</tr>
					}
				</tbody>
			</table>
		</div>
	</div>
}
