@using Microsoft.AspNetCore.Identity
@using WAMS.Models
@inject UserManager<User> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData["Title"] - HR</title>

	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
	<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

	<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
	<script src="https://cdn.jsdelivr.net/npm/countup.js@2.4.0/dist/countUp.min.js"></script>

	<style>
		body {
			background-color: #f4f6f9;
		}

		.hr-wrapper {
			display: flex;
			min-height: 100vh;
		}

		.hr-sidebar {
			width: 260px;
			background: #0d6efd;
			color: #fff;
		}

			.hr-sidebar a {
				color: #e7f1ff;
				text-decoration: none;
				padding: 0.75rem 1rem;
				display: block;
			}

				.hr-sidebar a:hover,
				.hr-sidebar a.active {
					background-color: #084298;
				}

		.hr-content {
			flex: 1;
			padding: 1.5rem;
		}

		.card {
			border-radius: 0.75rem;
			box-shadow: 0 2px 12px rgba(0,0,0,0.08);
		}
	</style>

	@RenderSection("Styles", required: false)
</head>

<body>
	<div class="hr-wrapper">

		<!-- SIDEBAR -->
		<aside class="hr-sidebar">
			<div class="p-3 border-bottom border-light">
				<h5>HR Portal</h5>
				<small>@User.Identity?.Name</small>
			</div>

			<nav class="mt-3">
				<a asp-controller="Dashboard" asp-action="Index">📊 Dashboard</a>
				<a asp-controller="HRApproval" asp-action="Index">📝 HR Approvals</a>
				<a asp-controller="Profile" asp-action="Index">👤 My Profile</a>
			</nav>
		</aside>

		<!-- MAIN CONTENT -->
		<div class="hr-content">

			<nav class="navbar navbar-light bg-white shadow-sm rounded mb-4 px-3">
				<span class="navbar-text">
					Welcome, <strong>@User.Identity?.Name</strong>
				</span>

				<form asp-controller="Login" asp-action="Logout" method="post">
					<button class="btn btn-outline-primary btn-sm">Logout</button>
				</form>
			</nav>

			@RenderBody()

			<footer class="text-center text-muted mt-4">
				<hr />
				<small>© 2026 WAMS · HR Portal</small>
			</footer>
		</div>
	</div>

	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
	@RenderSection("Scripts", required: false)
</body>
</html>
