@using Microsoft.AspNetCore.Identity
@using WAMS.Models
@inject UserManager<User> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <!-- CountUp -->
    <script src="https://cdn.jsdelivr.net/npm/countup.js@2.4.0/dist/countUp.min.js"></script>

    <style>
        body {
            background-color: #f4f6f9;
        }

        .admin-wrapper {
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar */
        .admin-sidebar {
            width: 250px;
            background: #1f2937;
            color: #fff;
        }

            .admin-sidebar a {
                color: #cbd5e1;
                text-decoration: none;
                padding: 0.75rem 1rem;
                display: block;
            }

                .admin-sidebar a:hover,
                .admin-sidebar a.active {
                    background-color: #374151;
                    color: #fff;
                }

        /* Content */
        .admin-content {
            flex: 1;
            padding: 1.5rem;
        }

        .card {
            border-radius: 0.75rem;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
            transition: transform 0.2s;
        }

            .card:hover {
                transform: translateY(-4px);
                box-shadow: 0 6px 20px rgba(0,0,0,0.12);
            }

        .metric-icon {
            font-size: 1.5rem;
        }

        .table-responsive {
            max-height: 350px;
            overflow-y: auto;
        }
    </style>

    @RenderSection("Styles", required: false)
</head>

<body>
    <div class="admin-wrapper">

        <!-- SIDEBAR -->
        <aside class="admin-sidebar">
            <div class="p-3 border-bottom">
                <h5 class="mb-0">WAMS Admin</h5>
                <small class="text-muted">Dashboard</small>
            </div>

            <nav class="mt-3">
                <a asp-controller="Dashboard" asp-action="Index">📊 Dashboard</a>
                <a asp-controller="Admin" asp-action="Users">👥 Users</a>
                <a asp-controller="Admin" asp-action="LeaveRequest">📄 Requests</a>
                <a asp-controller="Admin" asp-action="Reports">📈 Reports</a>
                @* <a asp-controller="Settings" asp-action="Index">⚙️ Settings</a> *@
            </nav>
        </aside>

        <!-- MAIN CONTENT -->
        <div class="admin-content">

            <!-- TOP NAV -->
            <nav class="navbar navbar-expand navbar-light bg-white shadow-sm rounded mb-4 px-3">
                <span class="navbar-text">
                    Welcome, <strong>@User.Identity?.Name</strong>
                </span>

                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <form asp-controller="Login" asp-action="Logout" method="post">
                            <button class="btn btn-outline-danger btn-sm">Logout</button>
                        </form>
                    </li>
                </ul>
            </nav>

            <!-- PAGE CONTENT -->
            @RenderBody()

            <!-- FOOTER -->
            <footer class="text-center text-muted mt-4">
                <hr />
                <small>© 2026 WAMS · Admin Panel</small>
            </footer>

        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>
