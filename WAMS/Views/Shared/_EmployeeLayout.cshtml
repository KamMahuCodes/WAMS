@using Microsoft.AspNetCore.Identity
@using WAMS.Models
@inject UserManager<User> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Employee</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <!-- CountUp -->
    <script src="https://cdn.jsdelivr.net/npm/countup.js@2.4.0/dist/countUp.min.js"></script>

    <style>
        body {
            background-color: #f4f6f9;
        }

        .employee-wrapper {
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar */
        .employee-sidebar {
            width: 240px;
            background: #0d6efd;
            color: #fff;
        }

            .employee-sidebar a {
                color: #e7f1ff;
                text-decoration: none;
                padding: 0.75rem 1rem;
                display: block;
            }

                .employee-sidebar a:hover,
                .employee-sidebar a.active {
                    background-color: #084298;
                    color: #fff;
                }

        /* Content */
        .employee-content {
            flex: 1;
            padding: 1.5rem;
        }

        .card {
            border-radius: 0.75rem;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
            transition: transform 0.2s;
        }

            .card:hover {
                transform: translateY(-3px);
                box-shadow: 0 6px 18px rgba(0,0,0,0.12);
            }
    </style>

    @RenderSection("Styles", required: false)
</head>

<body>
    <div class="employee-wrapper">

        <!-- SIDEBAR -->
        <aside class="employee-sidebar">
            <div class="p-3 border-bottom border-light">
                <h5 class="mb-0">Employee Portal</h5>
                <small>@User.Identity?.Name</small>
            </div>

            <nav class="mt-3">
                <a asp-controller="Dashboard" asp-action="Index">🏠 My Dashboard</a>
                <a asp-controller="LeaveRequest" asp-action="Create">📝 Request Leave</a>
                <a asp-controller="LeaveRequest" asp-action="Index">📄 Requests History</a>
                @* <a asp-controller="Profile" asp-action="Index">👤 My Profile</a> *@
            </nav>
        </aside>

        <!-- MAIN CONTENT -->
        <div class="employee-content">

            <!-- TOP BAR -->
            <nav class="navbar navbar-light bg-white shadow-sm rounded mb-4 px-3">
                <span class="navbar-text">
                    Welcome back, <strong>@User.Identity?.Name</strong>
                </span>

                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <form asp-controller="Login" asp-action="Logout" method="post">
                            <button class="btn btn-outline-light btn-sm text-primary">
                                Logout
                            </button>
                        </form>
                    </li>
                </ul>
            </nav>

            <!-- PAGE CONTENT -->
            @RenderBody()

            <!-- FOOTER -->
            <footer class="text-center text-muted mt-4">
                <hr />
                <small>© 2026 WAMS · Employee Portal</small>
            </footer>

        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>
