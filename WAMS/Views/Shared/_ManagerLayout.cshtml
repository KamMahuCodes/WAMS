@using Microsoft.AspNetCore.Identity
@using WAMS.Models
@inject UserManager<User> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Manager</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <!-- CountUp -->
    <script src="https://cdn.jsdelivr.net/npm/countup.js@2.4.0/dist/countUp.min.js"></script>

    <style>
        body {
            background-color: #f4f6f9;
        }

        .manager-wrapper {
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar */
        .manager-sidebar {
            width: 260px;
            background: #198754;
            color: #fff;
        }

            .manager-sidebar a {
                color: #e9f7ef;
                text-decoration: none;
                padding: 0.75rem 1rem;
                display: block;
            }

                .manager-sidebar a:hover,
                .manager-sidebar a.active {
                    background-color: #146c43;
                    color: #fff;
                }

        /* Content */
        .manager-content {
            flex: 1;
            padding: 1.5rem;
        }

        .card {
            border-radius: 0.75rem;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
            transition: transform 0.2s;
        }

            .card:hover {
                transform: translateY(-3px);
                box-shadow: 0 6px 18px rgba(0,0,0,0.12);
            }
    </style>

    @RenderSection("Styles", required: false)
</head>

<body>
    <div class="manager-wrapper">

        <!-- SIDEBAR -->
        <aside class="manager-sidebar">
            <div class="p-3 border-bottom border-light">
                <h5 class="mb-0">Manager Portal</h5>
                <small>@User.Identity?.Name</small>
            </div>

            <nav class="mt-3">
                <a asp-controller="Dashboard" asp-action="Index">📊 Dashboard</a>
                <a asp-controller="ManagerApproval" asp-action="Index">✅ Pending Approvals</a>
                <a asp-controller="ManagerApproval" asp-action="Index">👥 Team Requests</a>
                @* <a asp-controller="Profile" asp-action="Index">👤 My Profile</a> *@
            </nav>
        </aside>

        <!-- MAIN CONTENT -->
        <div class="manager-content">

            <!-- TOP BAR -->
            <nav class="navbar navbar-light bg-white shadow-sm rounded mb-4 px-3">
                <span class="navbar-text">
                    Welcome, <strong>@User.Identity?.Name</strong>
                </span>

                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <form asp-controller="Login" asp-action="Logout" method="post">
                            <button class="btn btn-outline-success btn-sm">
                                Logout
                            </button>
                        </form>
                    </li>
                </ul>
            </nav>

            <!-- PAGE CONTENT -->
            @RenderBody()

            <!-- FOOTER -->
            <footer class="text-center text-muted mt-4">
                <hr />
                <small>© 2026 WAMS · Manager Portal</small>
            </footer>

        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>
