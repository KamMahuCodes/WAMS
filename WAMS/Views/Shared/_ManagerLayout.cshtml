@using Microsoft.AspNetCore.Identity
@using WAMS.Models
@inject UserManager<User> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Manager</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <!-- CountUp -->
    <script src="https://cdn.jsdelivr.net/npm/countup.js@2.4.0/dist/countUp.min.js"></script>

    <style>
        body {
            min-height: 100vh;
            background: linear-gradient(rgba(8, 15, 35, 0.45), rgba(8, 15, 35, 0.45)), url('https://img.freepik.com/premium-photo/approve-document-through-magnifying-glass_21085-88758.jpg') no-repeat center center fixed;
            background-size: cover;
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
        }

        /* ===== TOP NAV ===== */
        .top-nav {
            backdrop-filter: blur(10px);
            background: rgba(15, 23, 42, 0.85);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

            .top-nav .nav-link {
                color: #cbd5f5 !important;
                font-weight: 500;
                padding: 0.75rem 1rem;
            }

                .top-nav .nav-link:hover,
                .top-nav .nav-link.active {
                    color: #38bdf8 !important;
                }

        .brand {
            font-weight: 700;
            letter-spacing: 0.5px;
        }

        /* ===== CONTENT GLASS ===== */
        .page-wrapper {
            padding: 2rem;
        }

        .content-glass {
            background: rgba(255, 255, 255, 0.88);
            border-radius: 1.25rem;
            padding: 2rem;
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.35);
        }

        /* ===== CARDS ===== */
        .card {
            background: rgba(255, 255, 255, 0.97);
            border-radius: 1rem;
            border: none;
            box-shadow: 0 12px 28px rgba(0, 0, 0, 0.15);
            transition: all 0.25s ease;
        }

            .card:hover {
                transform: translateY(-6px);
                box-shadow: 0 20px 45px rgba(0, 0, 0, 0.25);
            }

        /* ===== TABLE ===== */
        .table thead {
            background-color: #f1f5f9;
        }

        /* ===== FOOTER ===== */
        footer {
            color: #64748b;
        }
    </style>

    @RenderSection("Styles", required: false)
</head>

<body>

    <!-- ===== TOP NAVBAR ===== -->
    <nav class="navbar navbar-expand-lg navbar-dark top-nav px-4">
        <a class="navbar-brand brand" asp-controller="Dashboard" asp-action="Index">
            WAMS Manager
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#managerNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="managerNav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Dashboard" asp-action="Index">
                        Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="ManagerApproval" asp-action="Index">
                        Pending Approvals
                    </a>
                </li>
                @* <li class="nav-item">
                    <a class="nav-link" asp-controller="ManagerApproval" asp-action="TeamRequests">
                        Team Requests
                    </a>
                </li> *@
            </ul>

            <span class="navbar-text text-light me-3">
                Welcome, <strong>@User.Identity?.Name</strong>
            </span>

            <form asp-controller="Login" asp-action="Logout" method="post">
                <button class="btn btn-outline-warning btn-sm">
                    Logout
                </button>
            </form>
        </div>
    </nav>

    <!-- ===== PAGE CONTENT ===== -->
    <main class="page-wrapper">
        <div class="content-glass">
            @RenderBody()
        </div>

        <footer class="text-center mt-4">
            <small>© 2026 WAMS · Manager Portal</small>
        </footer>
    </main>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>
